# Normalize line endings to LF in the repo and on checkout, regardless of each
# contributor's core.autocrlf. This keeps the working tree consistent with
# Prettier's default endOfLine ("lf") so the two don't fight over line endings.
* text=auto eol=lf

# Explicitly mark known binary assets so Git never touches their bytes.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.woff binary
*.woff2 binary
